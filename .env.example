PORT=8787

# provider: solasgpt | ollama | openai
# solasgpt = your own trained model in /model/
PROVIDER=solasgpt

# Shared model name used by selected provider
MODEL=solasgpt

# Chat behavior
SYSTEM_PROMPT=You are a helpful, concise AI assistant inside a Scratch/TurboWarp project.
HISTORY_LIMIT=8

# For OPENAI-compatible providers
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# For local Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

# For SolasGPT (your own model, run inference_server.py)
SOLASGPT_URL=http://127.0.0.1:8788

# Security / abuse protection
# Comma-separated list of allowed browser origins.
# Use * only for local testing.
ALLOWED_ORIGINS=*

# Optional API key protection for /chat, /chat-plain, /reset
# Set REQUIRE_API_KEY=true in production and set API_KEYS.
REQUIRE_API_KEY=false
API_KEYS=

# Request limits
MAX_MESSAGE_LENGTH=500
MAX_SESSION_ID_LENGTH=64

# Per-IP rate limit window and max requests inside the window
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Safety controls
ENABLE_CONTENT_FILTER=true
SAFETY_REFUSAL_TEXT=I can't help with that.

# Optional visible reasoning summary (safe explanation, not raw chain-of-thought)
SHOW_REASONING_SUMMARY=false
REASONING_SUMMARY_MODE=brief

# Optional web search augmentation (DuckDuckGo + Wikipedia)
WEB_SEARCH_ENABLED=false
WEB_SEARCH_TIMEOUT_MS=4500
WEB_CONTEXT_MAX_CHARS=1200
WEB_RESULT_LIMIT=3

# Prevent oversized forwarded prompts when web context is enabled
SOLASGPT_FORWARD_MAX_CHARS=450

# Optional phrasing quality fallback
PHRASING_KNOWLEDGE_ENABLED=true
PHRASING_FALLBACK_ON_LOW_QUALITY=true